
    {% set grid_data = grid | default({}) %}
    {% set radius = grid_data.r | default(grid_data.radius | default(r | default(3))) %}
    {% set omitted_coords = grid_data.omit | default(grid_data.excluded | default(omit | default([]))) %}
    {% set aspect_items = aspects | default([]) %}
    {% set bg_image = background | default('parchment3.png') %}
    {% set aspect_base = aspect_base | default('aspects/') %}
    {% set size = 256 %}
    {% set margin = 25 %}
    {% set hex_size = (size - margin * 2) / (3 * radius + 2) %}
    {% set hex_width = 1.7320508075688772 * hex_size %}
    {% set hex_height = 2 * hex_size %}
    {% set step_x = 1.7320508075688772 * hex_size %}
    {% set step_y = 1.5 * hex_size %}
    {% set center = size / 2 %}
    {% set ns = namespace(omits='|', rendered='') %}
    {% for coord in omitted_coords %}
        {% set ns.omits = ns.omits ~ coord[0] ~ ',' ~ coord[1] ~ '|' %}
    {% endfor %}
    {% for item in aspect_items %}
        {% set coord = item.coord | default(item.coordinate | default(item[0])) %}
        {% set image = item.image | default(item.path | default(item[1])) %}
        {% set color = item.color | default(item[2] | default('#f5d14d')) %}
        {% set ns.rendered = ns.rendered ~ '<div class="aspect" style="--q:' ~ coord[0] ~ ';--r:' ~ coord[1] ~ ';--aspect-color:' ~ color ~ ';--aspect-image:url(\'' ~ aspect_base ~ image ~ '\');"></div>' %}
    {% endfor %}

    <div class="tcgame-board">
        <div class="honeycomb" style="--hex-size: {{ hex_size }}px; --hex-width: {{ hex_width }}px; --hex-height: {{ hex_height }}px; --step-x: {{ step_x }}px; --step-y: {{ step_y }}px; --center: {{ center }}px;">
            {% for q in range(-radius, radius + 1) %}
                {% for r_coord in range(-radius, radius + 1) %}
                    {% set s = -q - r_coord %}
                    {% if s >= -radius and s <= radius and ('|' ~ q ~ ',' ~ r_coord ~ '|') not in ns.omits %}
                        <div class="hex" style="--q: {{ q }}; --r: {{ r_coord }};"></div>
                    {% endif %}
                {% endfor %}
            {% endfor %}
            {{ ns.rendered | safe }}
        </div>
    </div>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            width: {{ size }}px;
            height: {{ size }}px;
            background: transparent;
            overflow: hidden;
        }

        .tcgame-board {
            position: relative;
            width: {{ size }}px;
            height: {{ size }}px;
            background-image: url("{{ bg_image }}");
            background-repeat: no-repeat;
            background-position: top left;
            background-size: {{ size }}px {{ size }}px;
            image-rendering: pixelated;
        }

        .honeycomb {
            position: absolute;
            inset: 0;
        }

        .hex,
        .aspect {
            position: absolute;
            left: calc(var(--center) + var(--step-x) * (var(--q) + var(--r) / 2) - var(--hex-width) / 2);
            top: calc(var(--center) + var(--step-y) * var(--r) - var(--hex-height) / 2);
            width: var(--hex-width);
            height: var(--hex-height);
            clip-path: polygon(50% 0%, 93.3% 25%, 93.3% 75%, 50% 100%, 6.7% 75%, 6.7% 25%);
        }

        .hex {
            background:
                radial-gradient(circle at 42% 38%, rgba(255, 232, 165, 0.2), transparent 36%),
                rgba(182, 119, 47, 0.055);
            border: 1.15px solid rgba(116, 83, 32, 0.28);
            filter: drop-shadow(0 0.5px 0 rgba(255, 238, 177, 0.32));
        }

        .hex::after {
            content: "";
            position: absolute;
            inset: 2px;
            clip-path: inherit;
            border: 1px solid rgba(255, 229, 151, 0.22);
        }

        .aspect {
            z-index: 2;
            transform: scale(0.62);
            background-color: var(--aspect-color);
            mask-image: var(--aspect-image);
            mask-repeat: no-repeat;
            mask-position: center;
            mask-size: contain;
            -webkit-mask-image: var(--aspect-image);
            -webkit-mask-repeat: no-repeat;
            -webkit-mask-position: center;
            -webkit-mask-size: contain;
            filter: drop-shadow(0 1px 1px rgba(48, 32, 10, 0.38));
        }
    </style>
